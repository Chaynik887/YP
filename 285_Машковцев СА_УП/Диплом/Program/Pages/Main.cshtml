                    (Model.UserRole.IndexOf("Директор", StringComparison.OrdinalIgnoreCase) >= 0 || 
                     Model.UserRole.IndexOf("Заместитель", StringComparison.OrdinalIgnoreCase) >= 0);
                
                @* отладка (показываем роль) *@
                @* <div style="background: yellow; padding: 10px; margin-bottom: 10px;">Роль: @Model.UserRole | isDirector: @isDirectorForProducts</div> *@
