                            @foreach (var product in Model.Products)
                            {
                                <tr class="@(product.IsActive && product.StockQuantity < 5 ? "low-stock-row" : "")">
                                    <td>@product.Name</td>
                                    <td>@(product.Description ?? "-")</td>
                                    <td>@product.Price.ToString("N2") ₽</td>
                                    @if (isDirectorForProducts)
                                    {
                                        <td>@product.CostPrice.ToString("N2") ₽</td>
                                        <td>
                                            @if (product.CostPrice > 0)
                                            {
                                                var markup = product.Price - product.CostPrice;
                                                var markupPercent = (markup / product.CostPrice * 100);
                                                <span>@markup.ToString("N2") ₽ (@markupPercent.ToString("N1")%)</span>
                                            }
                                            else
                                            {
                                                <span style="color: #6c757d;">-</span>
                                            }
                                        </td>
                                    }
                                    <td>
                                        @if (product.IsActive && product.StockQuantity < 5)
                                        {
                                            <span class="stock-badge @(product.StockQuantity == 0 ? "stock-zero-badge" : "stock-low-badge")">
                                                @product.StockQuantity
                                            </span>
                                        }
                                        else
                                        {
                                            @product.StockQuantity
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(product.IsActive ? "badge-success" : "badge-danger")">
                                            @(product.IsActive ? "Активен" : "Неактивен")
                                        </span>
                                    </td>
