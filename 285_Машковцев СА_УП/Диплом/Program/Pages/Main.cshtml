<div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="productModalLabel">Товар</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="SaveProduct">
                <div class="modal-body">
                    <input type="hidden" name="ProductId" id="productId" />
                    <div class="mb-3">
                        <label for="productName" class="form-label">Название *</label>
                        <input type="text" class="form-control" id="productName" name="Name" required />
                    </div>
                    <div class="mb-3">
                        <label for="productDescription" class="form-label">Описание</label>
                        <textarea class="form-control" id="productDescription" name="Description" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="productPrice" class="form-label">Цена продажи *</label>
                        <input type="text" inputmode="decimal" class="form-control" id="productPrice" name="Price" required placeholder="0.00" />
                    </div>
                    @if (Model.UserRole == "Директор" || Model.UserRole == "Заместитель директора")
                    {
                        <div class="mb-3">
                            <label for="productCostPrice" class="form-label">Закупочная цена</label>
                            <input type="text" inputmode="decimal" class="form-control" id="productCostPrice" name="CostPrice" placeholder="0.00" />
                            <small class="form-text text-muted">Цена, по которой товар был закуплен</small>
                        </div>
                    }
                    <div class="mb-3">
                        <label for="productStockQuantity" class="form-label">Количество на складе</label>
                        <input type="number" class="form-control" id="productStockQuantity" name="StockQuantity" min="0" value="0" />
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input type="hidden" name="IsActive" value="false" id="productIsActiveHidden" />
                            <input class="form-check-input" type="checkbox" id="productIsActive" onchange="document.getElementById('productIsActiveHidden').value = this.checked ? 'true' : 'false';" checked />
                            <label class="form-check-label" for="productIsActive">
                                Активен
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>

