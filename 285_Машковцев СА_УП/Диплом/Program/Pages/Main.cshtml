        </div>
    </div>
</div>

<script>
    // автоматический поиск при вводе
    const searchInput = document.querySelector('.search-box input');
    if (searchInput) {
        searchInput.addEventListener('input', function(e) {
            const form = e.target.closest('form');
            if (form) {
                clearTimeout(this.searchTimeout);
                this.searchTimeout = setTimeout(() => {
                    form.submit();
                }, 500);
            }
        });
    }

    // функции для открытия модальных окон
    function openProductModal(id, name, description, price, costPrice, stockQuantity, isActive) {
        document.getElementById('productId').value = id || '';
        document.getElementById('productName').value = name || '';
        document.getElementById('productDescription').value = description || '';
        document.getElementById('productPrice').value = price || '';
        const costPriceField = document.getElementById('productCostPrice');
        if (costPriceField) {
            costPriceField.value = costPrice || '';
        }
        document.getElementById('productStockQuantity').value = stockQuantity || 0;
        const checkbox = document.getElementById('productIsActive');
        const hiddenField = document.getElementById('productIsActiveHidden');
        checkbox.checked = isActive !== false && isActive !== 'false';
        hiddenField.value = checkbox.checked ? 'true' : 'false';
        document.getElementById('productModalLabel').textContent = id ? 'Редактировать товар' : 'Добавить товар';
    }

    function openProductModalFromButton(button) {
        const id = button.getAttribute('data-product-id');
        const name = button.getAttribute('data-product-name') || '';
        const description = button.getAttribute('data-product-description') || '';
        const price = button.getAttribute('data-product-price') || '';
        const costPrice = button.getAttribute('data-product-costprice') || '';
        const stockQuantity = button.getAttribute('data-product-stock') || '0';
        const isActive = button.getAttribute('data-product-active') === 'true';
        openProductModal(id, name, description, price, costPrice, stockQuantity, isActive);
    }

    function openServiceModal(id, name, description, price, isActive) {
        document.getElementById('serviceId').value = id || '';
        document.getElementById('serviceName').value = name || '';
        document.getElementById('serviceDescription').value = description || '';
        document.getElementById('servicePrice').value = price || '';
        const checkbox = document.getElementById('serviceIsActive');
        const hiddenField = document.getElementById('serviceIsActiveHidden');
        checkbox.checked = isActive !== false && isActive !== 'false';
        hiddenField.value = checkbox.checked ? 'true' : 'false';
        document.getElementById('serviceModalLabel').textContent = id ? 'Редактировать услугу' : 'Добавить услугу';
    }

    function openServiceModalFromButton(button) {
        const id = button.getAttribute('data-service-id');
        const name = button.getAttribute('data-service-name') || '';
        const description = button.getAttribute('data-service-description') || '';
        const price = button.getAttribute('data-service-price') || '';
        const isActive = button.getAttribute('data-service-active') === 'true';
        openServiceModal(id, name, description, price, isActive);
    }

    function openUserModal(id, login, fullName, phone, roleId, isActive) {
        document.getElementById('userId').value = id || '';
        document.getElementById('userLogin').value = login || '';
        document.getElementById('userPassword').value = '';
        document.getElementById('userFullName').value = fullName || '';
        document.getElementById('userPhone').value = phone || '';
        document.getElementById('userRoleId').value = roleId || '';
        
        const checkbox = document.getElementById('userIsActive');
        const hiddenField = document.getElementById('userIsActiveHidden');
        checkbox.checked = isActive !== false && isActive !== 'false';
        hiddenField.value = checkbox.checked ? 'true' : 'false';
        
        const passwordField = document.getElementById('userPassword');
        const passwordRequired = document.getElementById('passwordRequired');
        const passwordHint = document.getElementById('passwordHint');
        
        if (id) {
            passwordField.required = false;
            passwordRequired.style.display = 'none';
            passwordHint.style.display = 'block';
            document.getElementById('userModalLabel').textContent = 'Редактировать пользователя';
        } else {
            passwordField.required = true;
            passwordRequired.style.display = 'inline';
            passwordHint.style.display = 'none';
            document.getElementById('userModalLabel').textContent = 'Добавить пользователя';
        }
    }

    function openUserModalFromButton(button) {
        const id = button.getAttribute('data-user-id');
        const login = button.getAttribute('data-user-login') || '';
        const fullName = button.getAttribute('data-user-fullname') || '';
        const phone = button.getAttribute('data-user-phone') || '';
        const roleId = button.getAttribute('data-user-roleid') || '';
        const isActive = button.getAttribute('data-user-active') === 'true';
        openUserModal(id, login, fullName, phone, roleId, isActive);
    }

    function openRoleModal(id, roleName) {
        document.getElementById('roleId').value = id || '';
        document.getElementById('roleName').value = roleName || '';
        document.getElementById('roleModalLabel').textContent = id ? 'Редактировать роль' : 'Добавить роль';
    }

    // функции для работы с продажами
    let saleItemIndex = 0;
    const products = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Products.Where(p => p.IsActive).Select(p => new { p.ProductId, p.Name, p.Price, p.StockQuantity })));
    const services = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Services.Where(s => s.IsActive).Select(s => new { s.ServiceId, s.Name, s.Price })));
    let serviceOrderItemIndex = 0;

    function openSaleModal() {
        saleItemIndex = 0;
        document.getElementById('saleItemsContainer').innerHTML = '';
        document.getElementById('saleTotal').textContent = '0.00';
        addSaleItem();
    }


    function addSaleItem() {
        const container = document.getElementById('saleItemsContainer');
        const itemDiv = document.createElement('div');
        itemDiv.className = 'sale-item mb-3 p-3 border rounded';
        itemDiv.id = `saleItem_${saleItemIndex}`;
        itemDiv.innerHTML = `
            <div class="row">
                <div class="col-md-5">
                    <label class="form-label">Товар *</label>
                    <select class="form-select product-select" name="SaleItems[${saleItemIndex}].ProductId" required onchange="updateSaleItemPrice(${saleItemIndex})">
                        <option value="">Выберите товар</option>
                        ${products.map(p => {
                            const price = typeof p.Price === 'number' ? p.Price : parseFloat(p.Price);
                            const stock = typeof p.StockQuantity === 'number' ? p.StockQuantity : parseInt(p.StockQuantity);
                            return `<option value="${p.ProductId}" data-price="${price}" data-stock="${stock}">${p.Name} - ${price.toFixed(2)} ₽ (остаток: ${stock} шт.)</option>`;
                        }).join('')}
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Количество *</label>
                    <input type="number" class="form-control quantity-input" name="SaleItems[${saleItemIndex}].Quantity" min="1" value="1" required onchange="updateSaleTotal()" oninput="updateSaleTotal()">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Цена за шт. *</label>
                    <input type="number" step="0.01" class="form-control price-input" name="SaleItems[${saleItemIndex}].PriceAtSale" min="0" required onchange="updateSaleTotal()" oninput="updateSaleTotal()" placeholder="Выберите товар">
                </div>
                <div class="col-md-1">
                    <label class="form-label">&nbsp;</label>
                    <button type="button" class="btn btn-sm btn-danger w-100" onclick="removeSaleItem(${saleItemIndex})">✕</button>
                </div>
            </div>
        `;
        container.appendChild(itemDiv);
        saleItemIndex++;
    }

    function removeSaleItem(index) {
        const item = document.getElementById(`saleItem_${index}`);
        if (item) {
            item.remove();
            updateSaleTotal();
            // пересчитка индексов для правильной отправки формы
            reindexSaleItems();
        }
    }

    function reindexSaleItems() {
        const items = document.querySelectorAll('.sale-item');
        // НЕ удаляем пустые элементы перед отправкой - они могут быть валидными
        // просто пересчитываем индексы для всех элементов
        items.forEach((item, newIndex) => {
            // обновление ID элемента
            item.id = `saleItem_${newIndex}`;
            
            // обновление имен полей
            const productSelect = item.querySelector('.product-select');
            const quantityInput = item.querySelector('.quantity-input');
            const priceInput = item.querySelector('.price-input');
            
            if (productSelect) {
                productSelect.name = `SaleItems[${newIndex}].ProductId`;
                productSelect.setAttribute('onchange', `updateSaleItemPrice(${newIndex})`);
            }
            if (quantityInput) {
                quantityInput.name = `SaleItems[${newIndex}].Quantity`;
            }
            if (priceInput) {
                priceInput.name = `SaleItems[${newIndex}].PriceAtSale`;
            }
            
            // обновление кнопки удаления
            const removeBtn = item.querySelector('button[onclick*="removeSaleItem"]');
            if (removeBtn) {
                removeBtn.setAttribute('onclick', `removeSaleItem(${newIndex})`);
            }
        });
    }

    function updateSaleItemPrice(index) {
        const select = document.querySelector(`#saleItem_${index} .product-select`);
        const priceInput = document.querySelector(`#saleItem_${index} .price-input`);
        const quantityInput = document.querySelector(`#saleItem_${index} .quantity-input`);
        
        if (select && select.value) {
            const option = select.options[select.selectedIndex];
            const price = parseFloat(option.getAttribute('data-price'));
            const stock = parseInt(option.getAttribute('data-stock'));
            
            if (priceInput && !isNaN(price) && price > 0) {
                priceInput.value = price.toFixed(2);
                priceInput.readOnly = false; // разрешение редактирования, но устанавка значения по умолчанию
            }
            if (quantityInput) {
                quantityInput.max = stock;
                quantityInput.setAttribute('data-max-stock', stock);
                if (parseInt(quantityInput.value) > stock || parseInt(quantityInput.value) < 1) {
                    quantityInput.value = Math.min(Math.max(1, stock), parseInt(quantityInput.value) || 1);
                }
                // показ предупреждения, если остаток мал
                if (stock <= 0) {
                    quantityInput.style.borderColor = '#dc3545';
                    quantityInput.title = 'Товар отсутствует на складе';
                } else if (stock < 5) {
                    quantityInput.style.borderColor = '#ffc107';
                    quantityInput.title = 'Мало товара на складе';
                } else {
                    quantityInput.style.borderColor = '';
                    quantityInput.title = '';
                }
            }
            updateSaleTotal();
        } else {
            // если товар не выбран, очищаем поля
            if (priceInput) {
                priceInput.value = '';
                priceInput.readOnly = false;
            }
            if (quantityInput) {
                quantityInput.max = '';
                quantityInput.style.borderColor = '';
                quantityInput.title = '';
            }
        }
    }

    function updateSaleTotal() {
        let total = 0;
        document.querySelectorAll('.sale-item').forEach(item => {
            const quantity = parseFloat(item.querySelector('.quantity-input')?.value || 0);
            const price = parseFloat(item.querySelector('.price-input')?.value || 0);
            total += quantity * price;
        });
        document.getElementById('saleTotal').textContent = total.toFixed(2);
    }

    async function openSaleDetailsModal(saleId) {
        try {
            const response = await fetch(`/Main?handler=SaleDetails&id=${saleId}`);
            const html = await response.text();
            document.getElementById('saleDetailsContent').innerHTML = html;
        } catch (error) {
            document.getElementById('saleDetailsContent').innerHTML = '<p>Ошибка загрузки деталей продажи</p>';
        }
    }

    // обработка отправки формы продажи
    // использование делегирования событий, так как форма может быть в модальном окне
    document.addEventListener('submit', function(e) {
        const saleForm = e.target;
        if (saleForm && saleForm.id === 'saleForm') {
            console.log('Форма отправляется через submit event...');
            
            // пересчитка индексов перед отправкой
            reindexSaleItems();
            
            // проверка, что есть хотя бы один товар
            const items = document.querySelectorAll('.sale-item');
            console.log('Найдено товаров:', items.length);
            
            // проверка, что все товары выбраны и заполнены
            const validItems = [];
            let hasErrors = false;
            let errorMessage = 'Заполните все поля для всех товаров:\n';
            
            items.forEach((item, index) => {
                const productSelect = item.querySelector('.product-select');
                const quantityInput = item.querySelector('.quantity-input');
                const priceInput = item.querySelector('.price-input');
                
                const productId = productSelect?.value;
                const quantity = quantityInput?.value;
                const price = priceInput?.value;
                
                console.log(`Товар ${index + 1}:`, {
                    product: productId,
                    quantity: quantity,
                    price: price
                });
                
                if (!productId || productId === '0' || productId === '') {
                    hasErrors = true;
                    errorMessage += `- Товар ${index + 1}: выберите товар\n`;
                } else if (!quantity || parseInt(quantity) <= 0) {
                    hasErrors = true;
                    errorMessage += `- Товар ${index + 1}: укажите количество\n`;
                } else if (!price || parseFloat(price) <= 0) {
                    hasErrors = true;
                    errorMessage += `- Товар ${index + 1}: укажите цену\n`;
                } else {
                    validItems.push(item);
                }
            });
            
            if (validItems.length === 0) {
                e.preventDefault();
                alert('Добавьте хотя бы один товар в продажу');
                return false;
            }
            
            if (hasErrors) {
                e.preventDefault();
                alert(errorMessage);
                return false;
            }
            
            // показ индикатора загрузки
            const submitBtn = saleForm.querySelector('button[type="submit"], button[onclick="submitSaleForm()"]');
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Оформление...';
            }
            
            console.log('Форма валидна, отправка...');
            // форма будет отправлена автоматически
            return true;
        }
    });

    // функции для заказов услуг
    function openServiceOrderModal() {
        serviceOrderItemIndex = 0;
        document.getElementById('serviceOrderItemsContainer').innerHTML = '';
        document.getElementById('serviceOrderTotal').textContent = '0.00';
        document.getElementById('serviceOrderNotes').value = '';
        addServiceOrderItem();
    }

    function addServiceOrderItem() {
        const container = document.getElementById('serviceOrderItemsContainer');
        const itemDiv = document.createElement('div');
        itemDiv.className = 'service-order-item mb-3 p-3 border rounded';
        itemDiv.id = `serviceOrderItem_${serviceOrderItemIndex}`;
        itemDiv.innerHTML = `
            <div class="row">
                <div class="col-md-10">
                    <label class="form-label">Услуга *</label>
                    <select class="form-select service-select" name="ServiceOrderItems[${serviceOrderItemIndex}].ServiceId" required onchange="updateServiceOrderTotal()">
                        <option value="">Выберите услугу</option>
                        ${services.map(s => {
                            const price = typeof s.Price === 'number' ? s.Price : parseFloat(s.Price);
                            return `<option value="${s.ServiceId}" data-price="${price}">${s.Name} - ${price.toFixed(2)} ₽</option>`;
                        }).join('')}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="button" class="btn btn-sm btn-danger w-100" onclick="removeServiceOrderItem(${serviceOrderItemIndex})">✕</button>
                </div>
            </div>
        `;
        container.appendChild(itemDiv);
        serviceOrderItemIndex++;
    }

    function removeServiceOrderItem(index) {
        const item = document.getElementById(`serviceOrderItem_${index}`);
        if (item) {
            item.remove();
            updateServiceOrderTotal();
            reindexServiceOrderItems();
        }
    }

    function reindexServiceOrderItems() {
        const items = document.querySelectorAll('.service-order-item');
        // удаление пустых элементов (без выбранной услуги)
        items.forEach(item => {
            const serviceSelect = item.querySelector('.service-select');
            if (!serviceSelect || !serviceSelect.value) {
                item.remove();
            }
        });
        
        // Пересчёт индексов для оставшихся элементов
        const remainingItems = document.querySelectorAll('.service-order-item');
        remainingItems.forEach((item, newIndex) => {
            // обновление ID элемента
            item.id = `serviceOrderItem_${newIndex}`;
            
            // обновление имен полей
            const serviceSelect = item.querySelector('.service-select');
            if (serviceSelect) {
                serviceSelect.name = `ServiceOrderItems[${newIndex}].ServiceId`;
                serviceSelect.setAttribute('onchange', 'updateServiceOrderTotal()');
            }
            
            // обновление кнопки удаления
            const removeBtn = item.querySelector('button[onclick*="removeServiceOrderItem"]');
            if (removeBtn) {
                removeBtn.setAttribute('onclick', `removeServiceOrderItem(${newIndex})`);
            }
        });
    }

    function updateServiceOrderTotal() {
        let total = 0;
        document.querySelectorAll('.service-order-item').forEach(item => {
            const serviceSelect = item.querySelector('.service-select');
            if (serviceSelect && serviceSelect.value) {
                const option = serviceSelect.options[serviceSelect.selectedIndex];
                const price = parseFloat(option.getAttribute('data-price') || 0);
                total += price;
            }
        });
        document.getElementById('serviceOrderTotal').textContent = total.toFixed(2);
    }

    function submitServiceOrderForm() {
        const serviceOrderForm = document.getElementById('serviceOrderForm');
        if (!serviceOrderForm) {
            console.error('Форма не найдена');
            return;
        }
        
        // пересчёт индексов перед отправкой
        reindexServiceOrderItems();
        
        // проверка, что есть хотя бы одна услуга
        const items = document.querySelectorAll('.service-order-item');
        
        if (items.length === 0) {
            alert('Добавьте хотя бы одну услугу в заказ');
            return;
        }
        
        // проверка, что все услуги выбраны
        let hasErrors = false;
        let errorMessage = 'Заполните все поля:\n';
        
        items.forEach((item, index) => {
            const serviceSelect = item.querySelector('.service-select');
            
            if (!serviceSelect || !serviceSelect.value) {
                hasErrors = true;
                errorMessage += `- Услуга ${index + 1}: выберите услугу\n`;
            }
        });
        
        if (hasErrors) {
            alert(errorMessage);
            return;
        }
        
        // показ индикатора загрузки
        const submitBtn = serviceOrderForm.querySelector('button[onclick="submitServiceOrderForm()"]');
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Создание...';
        }
        
        // отправка формы
        serviceOrderForm.submit();
    }

    async function openServiceOrderDetailsModal(orderId) {
        try {
            const response = await fetch(`/Main?handler=ServiceOrderDetails&id=${orderId}`);
            const html = await response.text();
            document.getElementById('serviceOrderDetailsContent').innerHTML = html;
        } catch (error) {
            document.getElementById('serviceOrderDetailsContent').innerHTML = '<p>Ошибка загрузки деталей заказа</p>';
        }
    }

    // обработка отправки формы заказа услуг
    document.addEventListener('submit', function(e) {
        const serviceOrderForm = e.target;
        if (serviceOrderForm && serviceOrderForm.id === 'serviceOrderForm') {
            // пересчёт индексов перед отправкой
            reindexServiceOrderItems();
            
            // проверка, что есть хотя бы одна услуга
            const items = document.querySelectorAll('.service-order-item');
            
            if (items.length === 0) {
                e.preventDefault();
                alert('Добавьте хотя бы одну услугу в заказ');
                return false;
            }
            
            // проверка, что все услуги выбраны
            let hasErrors = false;
            let errorMessage = 'Заполните все поля:\n';
            
            items.forEach((item, index) => {
                const serviceSelect = item.querySelector('.service-select');
                
                if (!serviceSelect || !serviceSelect.value) {
                    hasErrors = true;
                    errorMessage += `- Услуга ${index + 1}: выберите услугу\n`;
                }
            });
            
            if (hasErrors) {
                e.preventDefault();
                alert(errorMessage);
                return false;
            }
            
            // показ индикатора загрузки
            const submitBtn = serviceOrderForm.querySelector('button[type="submit"]');
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Создание...';
            }
            
            return true;
        }
    });
    
    // функция для очистки фильтров
    function clearFilters() {
        const form = document.getElementById('searchForm');
        if (form) {
            // очистка всех полей фильтров
            const filterInputs = form.querySelectorAll('select[name^="filter"], input[name^="filter"]');
            filterInputs.forEach(input => {
                if (input.type === 'date') {
                    input.value = '';
                } else if (input.tagName === 'SELECT') {
                    input.selectedIndex = 0;
                }
            });
            // очистка поиска
            const searchInput = form.querySelector('input[name="search"]');
            if (searchInput) {
                searchInput.value = '';
            }
            form.submit();
        }
    }

    // функции для работы с поставками
    let supplyItemIndex = 0;
    const isDirectorUser = @Html.Raw((Model.UserRole == "Директор" || Model.UserRole == "Заместитель директора").ToString().ToLower());

    function openSupplyModal() {
        supplyItemIndex = 0;
        document.getElementById('supplyItemsContainer').innerHTML = '';
        document.getElementById('supplierName').value = '';
        document.getElementById('supplyNotes').value = '';
        const totalEl = document.getElementById('supplyTotal');
        if (totalEl) totalEl.textContent = '0.00';
        addSupplyItem();
    }

    function addSupplyItem() {
        const container = document.getElementById('supplyItemsContainer');
        const itemDiv = document.createElement('div');
        itemDiv.className = 'supply-item mb-3 p-3 border rounded';
        itemDiv.id = `supplyItem_${supplyItemIndex}`;
        
        let costPriceField = '';
        if (isDirectorUser) {
            costPriceField = `
                <div class="col-md-3">
                    <label class="form-label">Закуп. цена</label>
                    <input type="number" step="0.01" class="form-control cost-price-input" name="SupplyItems[${supplyItemIndex}].CostPrice" min="0" onchange="updateSupplyTotal()" oninput="updateSupplyTotal()" placeholder="0.00">
                </div>
            `;
        }
        
        itemDiv.innerHTML = `
            <div class="row">
                <div class="col-md-${isDirectorUser ? '5' : '8'}">
                    <label class="form-label">Товар *</label>
                    <select class="form-select supply-product-select" name="SupplyItems[${supplyItemIndex}].ProductId" required onchange="updateSupplyItemCostPrice(${supplyItemIndex})">
                        <option value="">Выберите товар</option>
                        ${products.map(p => {
                            return `<option value="${p.ProductId}">${p.Name}</option>`;
                        }).join('')}
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Количество *</label>
                    <input type="number" class="form-control supply-quantity-input" name="SupplyItems[${supplyItemIndex}].Quantity" min="1" value="1" required onchange="updateSupplyTotal()" oninput="updateSupplyTotal()">
                </div>
                ${costPriceField}
                <div class="col-md-1">
                    <label class="form-label">&nbsp;</label>
                    <button type="button" class="btn btn-sm btn-danger w-100" onclick="removeSupplyItem(${supplyItemIndex})">✕</button>
                </div>
            </div>
        `;
        container.appendChild(itemDiv);
        supplyItemIndex++;
    }

    function removeSupplyItem(index) {
        const item = document.getElementById(`supplyItem_${index}`);
        if (item) {
            item.remove();
            updateSupplyTotal();
            reindexSupplyItems();
        }
    }

    function reindexSupplyItems() {
        const items = document.querySelectorAll('.supply-item');
        items.forEach((item, newIndex) => {
            item.id = `supplyItem_${newIndex}`;
            
            const productSelect = item.querySelector('.supply-product-select');
            const quantityInput = item.querySelector('.supply-quantity-input');
            const costPriceInput = item.querySelector('.cost-price-input');
            
            if (productSelect) {
                productSelect.name = `SupplyItems[${newIndex}].ProductId`;
                productSelect.setAttribute('onchange', `updateSupplyItemCostPrice(${newIndex})`);
            }
            if (quantityInput) {
                quantityInput.name = `SupplyItems[${newIndex}].Quantity`;
            }
            if (costPriceInput) {
                costPriceInput.name = `SupplyItems[${newIndex}].CostPrice`;
            }
            
            const removeBtn = item.querySelector('button[onclick*="removeSupplyItem"]');
            if (removeBtn) {
                removeBtn.setAttribute('onclick', `removeSupplyItem(${newIndex})`);
            }
        });
    }

    function updateSupplyItemCostPrice(index) {
        // ????если директор, можно оставить поле пустым или заполнить
        // закупочная цена берётся из карточки товара на сервере, если не указана
        updateSupplyTotal();
    }

    function updateSupplyTotal() {
        if (!isDirectorUser) return;
        
        let total = 0;
        document.querySelectorAll('.supply-item').forEach(item => {
            const quantity = parseFloat(item.querySelector('.supply-quantity-input')?.value || 0);
            const costPrice = parseFloat(item.querySelector('.cost-price-input')?.value || 0);
            total += quantity * costPrice;
        });
        const totalEl = document.getElementById('supplyTotal');
        if (totalEl) totalEl.textContent = total.toFixed(2);
    }

    async function openSupplyDetailsModal(supplyId) {
        try {
            const response = await fetch(`/Main?handler=SupplyDetails&id=${supplyId}`);
            const html = await response.text();
            document.getElementById('supplyDetailsContent').innerHTML = html;
        } catch (error) {
            document.getElementById('supplyDetailsContent').innerHTML = '<p>Ошибка загрузки деталей поставки</p>';
        }
    }

    // валидация формы поставки
    document.addEventListener('submit', function(e) {
        const supplyForm = e.target;
        if (supplyForm && supplyForm.id === 'supplyForm') {
            // переиндексирование и отправка
            reindexSupplyItems();
            
            const submitBtn = supplyForm.querySelector('button[type="submit"]');
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Оформление...';
            }
            
            // разрешение отправки
            return true;
        }
    });
</script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
