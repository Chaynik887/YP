                                                data-product-description="@(product.Description ?? "")" 
                                                data-product-price="@product.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)" 
                                                data-product-costprice="@product.CostPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)" 
                                                data-product-stock="@product.StockQuantity" 
                                                data-product-active="@product.IsActive.ToString().ToLower()"
