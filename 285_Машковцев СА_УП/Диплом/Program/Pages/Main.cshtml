                                <table>
                                    <thead>
                                        <tr>
                                            <th>Дата</th>
                                            <th>Продаж</th>
                                            <th>Выручка</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var daily in Model.ReportData.SalesReport.DailySales)
                                        {
                                            <tr>
                                                <td>@daily.Date.ToString("dd.MM.yyyy")</td>
                                                <td>@daily.SalesCount</td>
                                                <td>@daily.Revenue.ToString("N2") ₽</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    }
                    
                    @if (Model.ReportData.ServicesReport != null)
                    {
                        <div style="margin-bottom: 24px;">
                            <h5 style="margin-bottom: 16px;">📊 Отчёт по услугам</h5>
                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px;">
                                <div style="background: #f8f9fa; padding: 16px; border-radius: 8px;">
                                    <div style="font-size: 12px; color: #6c757d; margin-bottom: 4px;">Общая выручка</div>
                                    <div style="font-size: 20px; font-weight: 600;">@Model.ReportData.ServicesReport.TotalRevenue.ToString("N2") ₽</div>
                                </div>
                                <div style="background: #f8f9fa; padding: 16px; border-radius: 8px;">
                                    <div style="font-size: 12px; color: #6c757d; margin-bottom: 4px;">Всего заказов</div>
                                    <div style="font-size: 20px; font-weight: 600;">@Model.ReportData.ServicesReport.TotalOrders</div>
                                </div>
                                <div style="background: #f8f9fa; padding: 16px; border-radius: 8px;">
                                    <div style="font-size: 12px; color: #6c757d; margin-bottom: 4px;">Средний чек</div>
                                    <div style="font-size: 20px; font-weight: 600;">@Model.ReportData.ServicesReport.AverageOrderAmount.ToString("N2") ₽</div>
                                </div>
                            </div>
                            
                            @if (Model.ReportData.ServicesReport.ServicesByMaster.Any())
                            {
                                <h6 style="margin-bottom: 12px;">Услуги по мастерам</h6>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Мастер</th>
                                            <th>Заказов</th>
                                            <th>Выручка</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var master in Model.ReportData.ServicesReport.ServicesByMaster)
                                        {
                                            <tr>
                                                <td>@master.MasterName</td>
                                                <td>@master.TotalOrders</td>
                                                <td>@master.TotalRevenue.ToString("N2") ₽</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    }
                    
                    @if (Model.ReportData.ProductsReport != null)
                    {
                        <div style="margin-bottom: 24px;">
                            <h5 style="margin-bottom: 16px;">📊 Отчёт по товарам</h5>
                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px;">
                                <div style="background: #f8f9fa; padding: 16px; border-radius: 8px;">
                                    <div style="font-size: 12px; color: #6c757d; margin-bottom: 4px;">Всего товаров</div>
                                    <div style="font-size: 20px; font-weight: 600;">@Model.ReportData.ProductsReport.TotalProducts</div>
                                </div>
                                <div style="background: #f8f9fa; padding: 16px; border-radius: 8px;">
                                    <div style="font-size: 12px; color: #6c757d; margin-bottom: 4px;">Активных</div>
                                    <div style="font-size: 20px; font-weight: 600;">@Model.ReportData.ProductsReport.ActiveProducts</div>
                                </div>
                                <div style="background: #f8f9fa; padding: 16px; border-radius: 8px;">
                                    <div style="font-size: 12px; color: #6c757d; margin-bottom: 4px;">Низкий остаток</div>
                                    <div style="font-size: 20px; font-weight: 600;">@Model.ReportData.ProductsReport.LowStockProducts</div>
                                </div>
                                <div style="background: #f8f9fa; padding: 16px; border-radius: 8px;">
                                    <div style="font-size: 12px; color: #6c757d; margin-bottom: 4px;">Стоимость склада</div>
                                    <div style="font-size: 20px; font-weight: 600;">@Model.ReportData.ProductsReport.TotalStockValue.ToString("N2") ₽</div>
                                </div>
                            </div>
                            
                            @if (Model.ReportData.ProductsReport.TopSellingProducts.Any())
                            {
                                <h6 style="margin-bottom: 12px;">Топ продаваемых товаров</h6>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Товар</th>
                                            <th>Продано</th>
                                            <th>Выручка</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var product in Model.ReportData.ProductsReport.TopSellingProducts)
                                        {
                                            <tr>
                                                <td>@product.ProductName</td>
                                                <td>@product.QuantitySold шт.</td>
                                                <td>@product.Revenue.ToString("N2") ₽</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    }
                    
                    @if (Model.ReportData.FinancialReport != null)
                    {
                        <div style="margin-bottom: 24px;">
                            <h5 style="margin-bottom: 16px;">📊 Финансовый отчёт</h5>
                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px;">
                                <div style="background: #d4edda; padding: 16px; border-radius: 8px;">
                                    <div style="font-size: 12px; color: #155724; margin-bottom: 4px;">Выручка от продаж</div>
                                    <div style="font-size: 20px; font-weight: 600; color: #155724;">@Model.ReportData.FinancialReport.SalesRevenue.ToString("N2") ₽</div>
                                </div>
                                <div style="background: #d4edda; padding: 16px; border-radius: 8px;">
                                    <div style="font-size: 12px; color: #155724; margin-bottom: 4px;">Выручка от услуг</div>
                                    <div style="font-size: 20px; font-weight: 600; color: #155724;">@Model.ReportData.FinancialReport.ServicesRevenue.ToString("N2") ₽</div>
                                </div>
                                <div style="background: #f8d7da; padding: 16px; border-radius: 8px;">
                                    <div style="font-size: 12px; color: #721c24; margin-bottom: 4px;">Затраты</div>
                                    <div style="font-size: 20px; font-weight: 600; color: #721c24;">@Model.ReportData.FinancialReport.TotalCost.ToString("N2") ₽</div>
                                </div>
                                <div style="background: @(Model.ReportData.FinancialReport.Profit >= 0 ? "#d4edda" : "#f8d7da"); padding: 16px; border-radius: 8px;">
                                    <div style="font-size: 12px; color: @(Model.ReportData.FinancialReport.Profit >= 0 ? "#155724" : "#721c24"); margin-bottom: 4px;">Прибыль</div>
                                    <div style="font-size: 20px; font-weight: 600; color: @(Model.ReportData.FinancialReport.Profit >= 0 ? "#155724" : "#721c24");">@Model.ReportData.FinancialReport.Profit.ToString("N2") ₽</div>
                                </div>
                            </div>
                            <div style="background: #f8f9fa; padding: 16px; border-radius: 8px;">
                                <div style="font-size: 14px; margin-bottom: 8px;"><strong>Общая выручка:</strong> @Model.ReportData.FinancialReport.TotalRevenue.ToString("N2") ₽</div>
                                <div style="font-size: 14px;"><strong>Рентабельность:</strong> @Model.ReportData.FinancialReport.ProfitMargin.ToString("N2")%</div>
                            </div>
                        </div>
                    }
                }
            }
        </div>
    </div>
</div>

