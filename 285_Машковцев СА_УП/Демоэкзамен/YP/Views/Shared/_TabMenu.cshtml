<div class="d-flex justify-content-between align-items-end mb-4 border-bottom">

    <ul class="nav nav-tabs border-0">
        <li class="nav-item">
            <a class="nav-link @ActiveTab("Index", "Requests")" asp-controller="Requests" asp-action="Index">Заявки</a>
        </li>
        @if (User.IsInRole("Оператор") || User.IsInRole("Менеджер"))
        {
            <li class="nav-item">
                <a class="nav-link @ActiveTab("Index", "Statistics")" asp-controller="Statistics" asp-action="Index">Статистика</a>
            </li>
        }
        @if (User.IsInRole("Оператор") || User.IsInRole("Менеджер") || User.IsInRole("Специалист"))
        {
            <li class="nav-item">
                <a class="nav-link @ActiveTab("Index", "Comments")" asp-controller="Comments" asp-action="Index">Комментарии</a>
            </li>
        }
    </ul>


    <div class="pb-2 d-flex align-items-center">
        <div class="me-3 text-end">
            <div class="fw-bold" style="font-size: 0.9rem;">@User.Identity?.Name</div>
            <span class="badge bg-info text-dark" style="font-size: 0.7rem;">
                @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
            </span>
        </div>
        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            <button type="submit" class="btn btn-outline-danger btn-sm" title="Выйти">
                Выход
            </button>
        </form>
    </div>
</div>

@functions {
    string ActiveTab(string action, string? controller = null)
    {
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

        if (!string.IsNullOrWhiteSpace(controller) && currentController != controller)
        {
            return "";
        }

        return currentAction == action ? "active" : "";
    }
}