@model YP.Models.Request
@{
    ViewData["Title"] = "Создать заявку";
}

<partial name="_TabMenu" />

<h3>Создать заявку</h3>

<form asp-action="Create" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-2">
        <label class="form-label">Дата добавления</label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>

    <div class="mb-2">
        <label class="form-label">Тип оборудования</label>
        <input asp-for="ClimateTechType" class="form-control" />
    </div>

    <div class="mb-2">
        <label class="form-label">Модель</label>
        <input asp-for="ClimateTechModel" class="form-control" />
    </div>

    <div class="mb-2">
        <label class="form-label">Описание проблемы</label>
        <textarea asp-for="ProblemDescription" class="form-control" rows="3"></textarea>
    </div>

    @if (User.IsInRole("Оператор") || User.IsInRole("Менеджер"))
    {
        <div class="mb-2">
            <label class="form-label">Статус</label>
            <select asp-for="StatusID" class="form-select" asp-items="ViewBag.StatusID"></select>
        </div>
    }
    else
    {
        <input type="hidden" asp-for="StatusID" />
    }

    @if (User.IsInRole("Оператор") || User.IsInRole("Менеджер"))
    {
        <div class="mb-3">
            <label class="form-label">Клиент</label>
            <select asp-for="ClientID" class="form-select" asp-items="ViewBag.ClientID"></select>
        </div>
    }

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

