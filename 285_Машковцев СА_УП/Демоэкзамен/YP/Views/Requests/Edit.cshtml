@model YP.Models.Request
@{
    ViewData["Title"] = "Редактировать заявку";
}

<partial name="_TabMenu" />

<h3>Редактировать заявку №@Model.RequestID</h3>

<form asp-action="Edit" method="post" class="mt-3">
    <input type="hidden" asp-for="RequestID" />
    <input type="hidden" asp-for="ClientID" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (User.IsInRole("Оператор") || User.IsInRole("Менеджер"))
    {
        <div class="mb-2">
            <label class="form-label">Дата добавления</label>
            <input asp-for="StartDate" type="date" class="form-control" />
        </div>

        <div class="mb-2">
            <label class="form-label">Тип оборудования</label>
            <input asp-for="ClimateTechType" class="form-control" />
        </div>

        <div class="mb-2">
            <label class="form-label">Модель</label>
            <input asp-for="ClimateTechModel" class="form-control" />
        </div>
    }

    <div class="mb-2">
        <label class="form-label">Описание проблемы</label>
        @if (User.IsInRole("Специалист"))
        {
            <textarea asp-for="ProblemDescription" class="form-control" rows="3" readonly></textarea>
        }
        else
        {
            <textarea asp-for="ProblemDescription" class="form-control" rows="3"></textarea>
        }
    </div>

    <div class="mb-2">
        <label class="form-label">Статус</label>
        @if (User.IsInRole("Заказчик"))
        {
            <select asp-for="StatusID" class="form-select" asp-items="ViewBag.StatusID" disabled></select>
            <input type="hidden" asp-for="StatusID" />
        }
        else
        {
            <select asp-for="StatusID" class="form-select" asp-items="ViewBag.StatusID"></select>
        }
    </div>

    @if (User.IsInRole("Оператор") || User.IsInRole("Менеджер"))
    {
        <div class="mb-2">
            <label class="form-label">Мастер</label>
            <select asp-for="MasterID" class="form-select" asp-items="ViewBag.MasterID">
                <option value="">(не назначен)</option>
            </select>
        </div>
    }
    else
    {
        <input type="hidden" asp-for="MasterID" />
    }

    @if (User.IsInRole("Оператор") || User.IsInRole("Менеджер") || User.IsInRole("Специалист"))
    {
        <div class="mb-2">
            <label class="form-label">Комплектующие</label>
            <textarea asp-for="RepairParts" class="form-control" rows="2"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Дата завершения</label>
            <input asp-for="CompletionDate" type="date" class="form-control" />
        </div>
    }

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a asp-action="Details" asp-route-id="@Model.RequestID" class="btn btn-outline-secondary">Назад</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

